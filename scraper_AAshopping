#!/usr/bin/env python3
import json
import os
import re
import smtplib
import urllib.request
from email.message import EmailMessage


TARGET_MERCHANTS = {
	"Adidas": 5,
	"Giftcards.com": 2,
	"eBay.com": 1.5,
	"Sur La Table": 3,
	"Apple": 2,

	# no miles expected, but always checking:
	"Amazon.com": 0.1
}

URL = "https://www.aadvantageeshopping.com/merchantlisthtml____.htm"

STATE_DIR = ".state"
STATE_FILE = os.path.join(STATE_DIR, "alerts_state.json")


def load_dotenv(file_path: str = ".env") -> None:
	if not os.path.exists(file_path):
		return

	with open(file_path, "r", encoding="utf-8") as env_file:
		for line in env_file:
			line = line.strip()
			if not line or line.startswith("#") or "=" not in line:
				continue

			key, value = line.split("=", 1)
			key = key.strip()
			value = value.strip().strip('"').strip("'")

			# Keep explicit shell/exported values as highest precedence.
			os.environ.setdefault(key, value)


def normalize(text: str) -> str:
	return re.sub(r"\s+", "", text).lower()


def merchant_key(text: str) -> str:
	# Canonicalize merchant names so minor label differences still match.
	value = text.lower()
	value = re.sub(r"\.com\b", "", value)
	value = re.sub(r"[^a-z0-9]+", "", value)
	return value


def load_state() -> dict:
	if not os.path.exists(STATE_FILE):
		return {"merchants": {}}

	try:
		with open(STATE_FILE, "r", encoding="utf-8") as state_file:
			return json.load(state_file)
	except (json.JSONDecodeError, OSError):
		return {"merchants": {}}


def save_state(state: dict) -> None:
	os.makedirs(STATE_DIR, exist_ok=True)
	with open(STATE_FILE, "w", encoding="utf-8") as state_file:
		json.dump(state, state_file, indent=2, sort_keys=True)


def should_send_alert(merchant_state: dict, threshold: float, current_value: float) -> tuple[bool, dict]:
	last_seen = merchant_state.get("last_seen_value")
	last_emailed = merchant_state.get("last_emailed_value")
	was_below = merchant_state.get("was_below_threshold")

	if was_below is None:
		# Backward-compatible migration from older state shape.
		# If we have already emailed while seen at/above threshold, do not resend.
		if last_emailed is not None and last_seen is not None and last_seen >= threshold:
			was_below = False
		else:
			was_below = True

	send = False

	if current_value < threshold:
		was_below = True
	else:
		if was_below:
			send = True
		was_below = False

	if send:
		last_emailed = current_value

	updated_state = {
		"last_seen_value": current_value,
		"last_emailed_value": last_emailed,
		"was_below_threshold": was_below,
	}
	return send, updated_state


def parse_miles_value(miles_text: str) -> float | None:
	match = re.search(r"(\d[\d,]*(?:\.\d+)?)", miles_text)
	if not match:
		return None
	return float(match.group(1).replace(",", ""))


def extract_miles(html: str, merchant_name: str) -> str | None:
	# Parse by merchant-name spans directly; the li markup can be malformed in this feed.
	target = merchant_key(merchant_name)
	name_matches = list(re.finditer(
		r'<span\s+class="mn_merchName"[^>]*>(.*?)</span>',
		html,
		flags=re.IGNORECASE | re.DOTALL,
	))

	for index, match in enumerate(name_matches):
		name = re.sub(r"<[^>]+>", "", match.group(1))
		name = re.sub(r"\s+", " ", name).strip()
		if merchant_key(name) != target:
			continue

		# Keep extraction inside this merchant entry to avoid bleeding into the next merchant.
		next_start = name_matches[index + 1].start() if index + 1 < len(name_matches) else min(len(html), match.end() + 2500)
		tail = html[match.end():next_start]
		matches = re.findall(r"(\d[\d,]*(?:\.\d+)?\s*miles?(?:\/\$)?)", tail, flags=re.IGNORECASE)
		if matches:
			# Elevated offers often include old and new values; latest value is typically the current one.
			return matches[-1]

	return None


def send_email(lines: list[str]) -> None:
	smtp_host = os.environ.get("SMTP_HOST", "smtp.gmail.com")
	smtp_port = int(os.environ.get("SMTP_PORT", "587"))
	smtp_username = os.environ.get("SMTP_USERNAME", "")
	smtp_password = os.environ.get("SMTP_PASSWORD", "")
	from_email = os.environ.get("EMAIL_FROM", smtp_username)

	if not smtp_username or not smtp_password or not from_email:
		print("Email not sent: set SMTP_USERNAME, SMTP_PASSWORD, and optionally EMAIL_FROM.")
		return
	email_to = os.environ.get("EMAIL_TO", "").strip()
	if not email_to:
		print("Email not sent: set EMAIL_TO.")
		return

	message = EmailMessage()
	message["Subject"] = "AAdvantage eShopping alerts"
	message["From"] = from_email
	message["To"] = email_to
	message.set_content("\n".join(lines))

	with smtplib.SMTP(smtp_host, smtp_port, timeout=30) as server:
		server.starttls()
		server.login(smtp_username, smtp_password)
		server.send_message(message)

	print(f"Email sent to {email_to}")


def main() -> None:
	load_dotenv()
	state = load_state()

	request = urllib.request.Request(
		URL,
		headers={
			"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 "
			"(KHTML, like Gecko) Chrome/127.0.0.0 Safari/537.36"
		},
	)

	with urllib.request.urlopen(request, timeout=30) as response:
		html = response.read().decode("utf-8", errors="replace")

	qualifying_lines: list[str] = []
	met_threshold_lines: list[str] = []
	merchant_states = state.setdefault("merchants", {})

	for merchant, minimum_miles in TARGET_MERCHANTS.items():
		miles = extract_miles(html, merchant)
		if not miles:
			print(f"{merchant}: NOT FOUND")
			continue

		value = parse_miles_value(miles)
		if value is None:
			print(f"{merchant}: {miles} (unparseable)")
			continue

		merchant_state = merchant_states.get(merchant, {})
		should_send, updated_state = should_send_alert(merchant_state, float(minimum_miles), value)
		merchant_states[merchant] = updated_state

		print(f"{merchant}: {miles} (min {minimum_miles})")
		if value >= float(minimum_miles):
			met_threshold_lines.append(f"{merchant}: {miles} (>= {minimum_miles})")
			if should_send:
				qualifying_lines.append(f"{merchant}: {miles} (>= {minimum_miles})")

	save_state(state)

	if qualifying_lines:
		send_email(["Merchants meeting threshold:", "", *qualifying_lines])
	else:
		if met_threshold_lines:
			print("Merchants met threshold, but no new alert condition was triggered. No email sent.")
		else:
			print("No merchants met threshold. No email sent.")


if __name__ == "__main__":
	main()
